FROM debian:bookworm-slim

ARG TARGETARCH

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY docker/linux-${TARGETARCH}/mach /app/mach
RUN chmod 0755 /app/mach \
    # Smoke test: verify the binary starts and is executable.
    && /app/mach --version

CMD ["/app/mach"]
